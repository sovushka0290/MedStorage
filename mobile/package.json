{
  "name": "medsklad-mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "postinstall": "node -e \"const fs=require('fs');['./node_modules/nativewind/node_modules/react-native-css-interop/babel.js','./node_modules/react-native-css-interop/babel.js'].forEach(p=>{if(fs.existsSync(p)){fs.writeFileSync(p,fs.readFileSync(p,'utf8').replace('react-native-worklets/plugin','react-native-reanimated/plugin'));}});\"",
    "eas-build-post-install": "npm run postinstall"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "axios": "^1.7.2",
    "expo": "~55.0.27",
    "expo-camera": "~55.0.20",
    "expo-constants": "~55.0.16",
    "expo-font": "~55.0.8",
    "expo-image-manipulator": "~55.0.18",
    "expo-linking": "~55.0.16",
    "expo-router": "~55.0.16",
    "expo-secure-store": "~55.0.15",
    "nativewind": "^4.0.1",
    "react": "19.2.0",
    "react-native": "0.83.6",
    "react-native-css-interop": "^0.2.6",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-worklets": "^0.7.4",
    "react-native-worklets-core": "^1.6.3",
    "tailwindcss": "^3.4.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/react": "~19.2.10",
    "babel-preset-expo": "~55.0.8",
    "typescript": "^5.3.3"
  },
  "private": true
}
